# Compose image tags
ATHENA_IMAGE=athena:local
ATHENA_WEB_IMAGE=athena-web:local

# Published ports
ATHENA_HTTP_PORT=8090
ATHENA_WEB_PORT=5173
POSTGRES_PORT=5432

# Compose profile
# Set COMPOSE_PROFILES=control-plane when athena-web is needed.
COMPOSE_PROFILES=

# PostgreSQL container bootstrap
POSTGRES_DB=secure_digital
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# Athena runtime config
HTTP_PORT=8080
SESSION_STORE_DRIVER=postgres
MODEL_STORE_DRIVER=postgres
SECURITY_ENCRYPTION_KEY=replace-with-a-real-secret
CONTROL_PLANE_ALLOWED_ORIGINS=http://localhost:5173
CONTROL_PLANE_STORE_PATH=config/controlplane/overrides.json
SHARED_ROOT_DIR=/srv/shared
OBSERVABILITY_LOG_LEVEL=info

# Shared PostgreSQL connection
DB_TYPE=postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=secure_digital
DB_USERNAME=postgres
DB_PASSWORD=change-me
DB_CONFIG=sslmode=disable search_path=athena client_encoding=UTF8
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=70
DB_CONN_MAX_LIFETIME_SECONDS=300
DB_LOG_MODE=false
DB_LOG_ZAP=info

# Optional platform context client
# PLATFORM_CONTEXT_BASE_URL=https://platform.example.com
# PLATFORM_CONTEXT_DETAIL_TIMEOUT_SECONDS=5
# PLATFORM_CONTEXT_AUTH_HEADER=Authorization
# PLATFORM_CONTEXT_AUTH_TOKEN=
# PLATFORM_CONTEXT_FORWARD_AUTHORIZATION=true
